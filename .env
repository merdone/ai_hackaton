# -----------------------------
# App (Streamlit UI)
# -----------------------------
APP_FEATURES_FILE=./data/output/features_temp.json
APP_DATASET_FILE=./data/output/labeled_dataset.csv
APP_MODEL_FILE=./models/rf_v1.pkl
APP_PREVIEW_VIDEO_PATH=./data/output/preview_with_ids.mp4
APP_ORIGINAL_VIDEO_PATH=./data/input/video2.mkv

# -----------------------------
# Worker (event generator)
# -----------------------------
WORKER_DB_PATH=/app/data/events.db
WORKER_SLEEP_SECONDS=2.0
WORKER_IDS=ID_1,ID_2,ID_3
WORKER_ACTIONS=Moving,Sorting,Idle
WORKER_ZONES=Zone_A,Zone_B
WORKER_CONFIDENCE_MIN=0.65
WORKER_CONFIDENCE_MAX=0.99
WORKER_TIMESTAMP_FORMAT=%Y-%m-%d %H:%M:%S

# -----------------------------
# Worker YOLO extraction
# -----------------------------
WORKER_YOLO_MODEL_PATH=./models/best.pt
WORKER_YOLO_VIDEO_PATH=./data/input/video2.mkv
WORKER_YOLO_PREVIEW_PATH=./data/output/preview_with_ids.mp4
WORKER_YOLO_FEATURES_PATH=./data/output/features_temp.json
WORKER_YOLO_TRACKER=bytetrack.yaml
# CSV list of class ids
WORKER_YOLO_CLASSES=0
WORKER_YOLO_IMGSZ=640
WORKER_YOLO_CONF=0.5
WORKER_YOLO_DEVICE=cuda
WORKER_YOLO_PREVIEW_WIDTH=1280
WORKER_YOLO_PREVIEW_HEIGHT=720
WORKER_YOLO_WINDOW_NAME=Features Extractor
WORKER_ZONE_ANNOTATOR_WINDOW_NAME=Zone Annotator
WORKER_YOLO_ZONES_PATH=./data/output/zones.json
WORKER_YOLO_DRAW_ZONES=true
# true/false, 1/0, yes/no are supported
WORKER_YOLO_SHOW_WINDOW=true
# OpenCV fourcc code
WORKER_YOLO_FOURCC=avc1

